        // ==================== PASS FUNCTIONS ====================
        function checkSubscription() {
            const stored = localStorage.getItem('men_pass_subscriber');
            isSubscriber = stored === 'true';
            return isSubscriber;
        }

        function setSubscription(status) {
            isSubscriber = status;
            localStorage.setItem('men_pass_subscriber', status ? 'true' : 'false');
            updateUIForSubscription();
        }

        function updateUIForSubscription() {
            // Show/hide premium games
            document.querySelectorAll('.premium-game').forEach(el => {
                el.style.display = isSubscriber ? 'block' : 'none';
            });
            // Hide ads for subscribers
            const ad = document.getElementById('fixedAd');
            if (ad) {
                ad.style.display = isSubscriber ? 'none' : 'block';
            }
            // Update pass banner button
            const passBtns = document.querySelectorAll('.btn-pass, .btn-pass-sm');
            passBtns.forEach(btn => {
                if (isSubscriber) {
                    btn.innerHTML = '<i class="fas fa-check-circle"></i> مشترك';
                    btn.style.background = 'linear-gradient(135deg, #4caf50, #2e7d32)';
                    btn.style.boxShadow = '0 4px 24px rgba(76,175,80,0.3)';
                } else {
                    btn.innerHTML = '<i class="fas fa-crown"></i> اشترك الآن';
                    btn.style.background = 'linear-gradient(135deg, #f5b342, #e8912e)';
                    btn.style.boxShadow = '0 4px 24px rgba(245,179,66,0.3)';
                }
            });
            // Update pass banner text
            const banner = document.getElementById('passBanner');
            if (banner) {
                const textEl = banner.querySelector('.pass-text p');
                if (isSubscriber) {
                    textEl.textContent = '🎉 أنت مشترك في MEN Pass! استمتع بكل المزايا الحصرية.';
                    const btns = banner.querySelectorAll('.btn-pass');
                    btns.forEach(b => {
                        b.innerHTML = '<i class="fas fa-check-circle"></i> مفعل';
                        b.style.background = 'linear-gradient(135deg, #4caf50, #2e7d32)';
                        b.style.boxShadow = '0 4px 24px rgba(76,175,80,0.3)';
                    });
                } else {
                    textEl.textContent = 'افتح عالم الألعاب والمحتوى الحصري مع اشتراك MEN Pass. استمتع بتجربة لا مثيل لها.';
                }
            }
        }

        function subscribeToPass() {
            setSubscription(true);
            showToast('🎉 تم تفعيل اشتراك MEN Pass بنجاح! استمتع بكل المزايا.', 'success');
            document.getElementById('passPopup').classList.remove('active');
            updateUIForSubscription();
            // Also add to cart for tracking
            const passProduct = productsArray.find(p => p.id === 999);
            if (passProduct) {
                addToCart(passProduct);
            }
        }

        function showPassPopup() {
            document.getElementById('passPopup').classList.add('active');
        }

        // ==================== UTILITIES ====================
        function showToast(msg, type = "info") {
            const old = document.querySelector('.toast-notification');
            if (old) old.remove();
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            let icon = type === 'success' ? '<i class="fas fa-check-circle"></i>' : (type === 'error' ?
                '<i class="fas fa-times-circle"></i>' : '<i class="fas fa-info-circle"></i>');
            if (msg.includes('MEN Pass')) icon = '<i class="fas fa-crown pass-icon"></i>';
            toast.innerHTML = `${icon} <span>${msg}</span>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 5000);
        }

        async function sendToWebhook(url, data, successMsg) {
            try {
                await fetch(url, { method: "POST", headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(data) });
                if (successMsg) showToast(successMsg, "success");
            } catch (e) { showToast("فشل الإرسال", "error"); }
        }

        function buildBaseEmbed(title, color, additional = []) {
            return {
                title,
                color,
                fields: [
                    { name: "الاسم الكامل", value: currentUserData?.fullName || "زائر", inline: true },
                    { name: "الرقم الوظيفي", value: currentUserData?.userId || "—", inline: true },
                    { name: "رقم الجوال", value: currentUserData?.phone || "—", inline: true },
                    ...additional
                ],
                timestamp: new Date().toISOString()
            };
        }

        // ==================== INTELLIGENT FUNCTIONS ====================
        function similarity(s1, s2) {
            if (!s1 || !s2) return 0;
            const a = s1.toLowerCase().trim(),
                b = s2.toLowerCase().trim();
            if (a === b) return 1;
            let longer = a.length >= b.length ? a : b;
            let shorter = a.length < b.length ? a : b;
            if (longer.length === 0) return 0;
            let cost = 0;
            for (let i = 0; i < shorter.length; i++) { if (longer[i] !== shorter[i]) cost++; }
            return (longer.length - cost) / longer.length;
        }

        function extractKeywords(text) {
            const stopWords = ["ابغى", "اريد", "أبغى", "أريد", "عندي", "كم", "ما", "هل", "بـ", "ريال", "ريالات", "جديد",
                "مناسب", "افضل", "أفضل", "و", "في", "من", "الى", "على", "عن", "مع", "سعر", "السعر"
            ];
            const words = text.split(/[\s,،]+/).filter(w => w.length > 1);
            const keywords = [];
            let priceRange = null;
            for (let w of words) {
                const num = parseFloat(w.replace(/[^0-9.]/g, ''));
                if (!isNaN(num) && num > 0) priceRange = num;
                else if (!stopWords.includes(w)) keywords.push(w);
            }
            return { keywords, priceRange };
        }

        function findClosestMatch(query) {
            const { keywords, priceRange } = extractKeywords(query);
            if (keywords.length === 0 && !priceRange) return { products: [], exact: false };
            let candidates = productsArray,
                result = [];
            for (let p of candidates) {
                let bestSim = 0;
                for (let kw of keywords) {
                    let sim = similarity(kw, p.name);
                    if (sim > bestSim) bestSim = sim;
                    for (let tag of p.tags) { let s = similarity(kw, tag); if (s > bestSim) bestSim = s; }
                }
                let inRange = true;
                if (priceRange) { const pPrice = parseFloat(p.price); if (pPrice < priceRange * 0.5 || pPrice >
                        priceRange * 2) inRange = false; }
                if (bestSim > 0.3 && inRange) result.push({ product: p, sim: bestSim });
            }
            if (result.length === 0) {
                for (let p of candidates) {
                    let bestSim = 0;
                    for (let kw of keywords) {
                        let s = similarity(kw, p.name);
                        if (s > bestSim) bestSim = s;
                        for (let tag of p.tags) { let t = similarity(kw, tag); if (t > bestSim) bestSim = t; }
                    }
                    if (bestSim > 0.2) result.push({ product: p, sim: bestSim });
                }
            }
            result.sort((a, b) => b.sim - a.sim);
            const unique = [];
            const ids = new Set();
            for (let r of result) { if (!ids.has(r.product.id)) { ids.add(r.product.id);
                    unique.push(r); } }
            return { products: unique.map(r => r.product), exact: unique.length > 0 && unique[0].sim > 0.75 };
        }

        // ==================== CORE AI RESPONSE ====================
        function getAIResponse(userText) {
            const lower = userText.toLowerCase();
            const { keywords, priceRange } = extractKeywords(userText);

            // === MEN Pass detection ===
            if (lower.includes('pass') || lower.includes('اشتراك') || lower.includes('مين باس') ||
                lower.includes('men pass') || lower.includes('الباس') || lower.includes('كروان') ||
                (keywords.some(k => ['pass', 'باس', 'اشتراك', 'عضوية', 'مميز', 'كروان', 'تاج'].includes(k)))) {
                if (isSubscriber) {
                    return `👑 أنت مشترك بالفعل في <span class="pass-highlight">MEN Pass</span>! 🎉\n\nاستمتع بكل المزايا:\n✅ ألعاب حصرية\n✅ فيديوهات للمشتركين\n✅ بحوث متقدمة\n✅ تجربة بدون إعلانات\n\n📌 هل تريد معرفة المزيد عن أي ميزة؟`;
                }
                return `👑 <span class="pass-highlight">MEN Pass</span> — اشتراكك المميز\n\n📦 السعر: <strong>29.99 ر.س</strong> / شهر\n\n🎁 <strong>المزايا:</strong>\n• 🎮 <strong>ألعاب أكثر</strong> — مكتبة ألعاب حصرية تتوسع باستمرار\n• 🎬 <strong>فيديوهات المشتركين</strong> — محتوى فيديو حصري للمشتركين\n• 🔬 <strong>بحوث متقدمة</strong> — تحليلات واستراتيجيات احترافية\n• 🚫 <strong>بدون إعلانات</strong> — تجربة نظيفة وخالية من الإعلانات\n\n💡 كيف تشترك؟\n• من خلال المتجر (منتج MEN Pass)\n• أو اضغط على زر "اشترك الآن" في البanner\n• أو اطلب مني "أضف MEN Pass" للسلة\n\n🔹 هل تريد إضافته إلى سلة المشتريات؟ اكتب "أضف MEN Pass"`;
            }

            if (lower.includes('مرحب') || lower.includes('سلام') || lower.includes('اهلا') || lower.includes('hi') ||
                lower.includes('hello')) {
                return `👋 أهلاً وسهلاً! أنا مساعد MEN الذكي.\n\nأستطيع مساعدتك في:\n• عرض المنتجات والبحث عنها.\n• مقارنة المنتجات.\n• نصائح الشراء.\n• تتبع الطلبات.\n• العروض والكوبونات.\n• إدارة السلة والمفضلة.\n• <span class="pass-highlight">معلومات عن MEN Pass</span>\n\n📌 اكتب ما تريده بالعربية، وسأفهمك.`;
            }
            if (lower.includes('شكر') || lower.includes('thank')) return '🙏 الشكر لك! أنا هنا لخدمتك دائماً. هل تحتاج مساعدة أخرى؟ 😊';

            if (lower.includes('سلتي') || lower.includes('ماذا في السلة') || lower.includes('show cart') || lower.includes(
                    'my cart')) {
                return getCartSummaryHTML() + '\n\n📌 هل تريد إضافة منتج معين أو إزالة شيء؟';
            }

            if (lower.includes('مفضلة') || lower.includes('المفضلة') || lower.includes('favorite')) return getFavoritesHTML();

            if (lower.includes('تتبع') || lower.includes('أين طلبي') || lower.includes('track') || lower.includes(
                'order')) {
                const orderId = lower.match(/\d+/)?.[0] || "2026-001";
                return simulateTrackOrder(orderId);
            }

            if (lower.includes('عرض') || lower.includes('خصم') || lower.includes('كوبون') || lower.includes('offer') ||
                lower.includes('discount') || lower.includes('coupon')) {
                let category = null;
                for (let kw of keywords) { const cat = getCategoryFromWord(kw); if (cat) { category = cat; break; } }
                return getPersonalizedOffers(category);
            }

            if (lower.includes('قارن') || lower.includes('compare') || lower.includes('مقارنة')) {
                let found = [];
                for (let kw of keywords) {
                    for (let p of productsArray) {
                        if (p.name.toLowerCase().includes(kw) || kw.includes(p.name.toLowerCase())) {
                            if (!found.includes(p.id)) found.push(p.id);
                        }
                    }
                }
                if (found.length < 2) {
                    const search = findClosestMatch(userText);
                    if (search.products.length >= 2) found = search.products.slice(0, 2).map(p => p.id);
                    else return "⚠️ للمقارنة، اذكر منتجين بالاسم، مثل: 'قارن بين تيشيرت وستور'";
                }
                const p1 = productsArray.find(p => p.id === found[0]);
                const p2 = productsArray.find(p => p.id === found[1]);
                if (!p1 || !p2) return "⚠️ لم أجد المنتجين للمقارنة، حاول كتابة الأسماء بدقة.";
                return `⚖️ **مقارنة بين ${p1.name} و ${p2.name}**\n\n| الخاصية | ${p1.name} | ${p2.name} |\n|---|---|---|\n| السعر | ${p1.price} ر.س | ${p2.price} ر.س |\n| التقييم | ${p1.rating}/5 | ${p2.rating}/5 |\n| التصنيف | ${p1.category} | ${p2.category} |\n| المميزات | ${p1.features.join('، ')} | ${p2.features.join('، ')} |\n| العيوب | ${p1.cons.join('، ') || 'لا يوجد'} | ${p2.cons.join('، ') || 'لا يوجد'} |\n| الضمان | ${p1.warranty} | ${p2.warranty} |\n\n💡 **المناسب لك:** ${p1.rating >= p2.rating ? p1.name : p2.name} بناءً على التقييم والسعر.`;
            }

            if (lower.includes('هدية') || lower.includes('gift')) {
                const suggestions = getGiftSuggestions();
                if (suggestions.length === 0) return "🎁 لا توجد منتجات مناسبة كهدية حالياً، لكن يمكنك الاطلاع على المتجر.";
                return `🎁 **هدايا مقترحة:**\n\n${suggestions.map(p => `- **${p.name}** (${p.price} ر.س) - تقييم ${p.rating}/5\n  ${p.description.substring(0, 60)}...`).join('\n\n')}\n\n💡 هل تريد إضافة أي منها للسلة؟`;
            }

            if (lower.includes('للدراسة') || lower.includes('دراسة') || lower.includes('study')) {
                const suggestions = productsArray.filter(p => p.tags.includes("سفر") || p.category === "إلكترونيات");
                if (suggestions.length === 0) return "📚 ليس لدينا منتجات مخصصة للدراسة حالياً، لكن يمكنك تصفح المتجر.";
                return `📚 منتجات قد تناسب الدراسة:\n\n${suggestions.map(p => `- ${p.name} (${p.price} ر.س) - ${p.description.substring(0, 50)}...`).join('\n')}`;
            }

            const searchResult = findClosestMatch(userText);
            if (searchResult.products.length > 0) {
                if (searchResult.products.length === 1 || searchResult.exact) {
                    const p = searchResult.products[0];
                    lastViewedProductId = p.id;
                    if (!viewedHistory.includes(p.id)) viewedHistory.push(p.id);
                    return getProductAdvice(p.id) + `\n\n🛒 هل تريد إضافته للسلة؟ اكتب "أضف ${p.name}"`;
                } else {
                    let list = searchResult.products.map(p => `- ${p.name} (${p.price} ر.س) - ${p.category}`)
                        .join('\n');
                    return `🔎 نتائج البحث عن "${userText}":\n\n${list}\n\n📌 اختر واحداً واكتب اسمه للحصول على تفاصيل أكثر.`;
                }
            }

            if (lower.includes('أضف') || lower.includes('add')) {
                let target = null;
                for (let kw of keywords) { const found = productsArray.find(p => p.name.toLowerCase().includes(kw)); if (
                        found) { target = found; break; } }
                if (!target && lastViewedProductId) target = productsArray.find(p => p.id === lastViewedProductId);
                if (!target) { const sr = findClosestMatch(userText); if (sr.products.length > 0) target = sr
                        .products[0]; }
                if (target) {
                    addToCart(target);
                    if (target.id === 999) {
                        // If it's the Pass, offer to subscribe
                        return `✅ تمت إضافة <span class="pass-highlight">${target.name}</span> إلى السلة!\n\n👑 هل ترغب في تفعيل الاشتراك الآن؟ اكتب "اشترك Pass" أو اضغط على زر الاشتراك في المتجر.\n\n${getProductAdvice(target.id)}`;
                    }
                    return `✅ تمت إضافة ${target.name} إلى السلة!\n\n${getProductAdvice(target.id)}\n\n🛒 سلتك تحتوي الآن على ${cartItems.length} منتج.`;
                } else return "⚠️ لم أتمكن من تحديد المنتج الذي تريد إضافته. اكتب اسم المنتج بدقة.";
            }

            if (lower.includes('اشترك') && (lower.includes('pass') || lower.includes('باس'))) {
                if (isSubscriber) return '👑 أنت مشترك بالفعل في MEN Pass! استمتع بكل المزايا. 🎉';
                return `👑 **تفعيل اشتراك MEN Pass**\n\nلتفعيل اشتراكك، يمكنك:\n1. إضافته إلى السلة: اكتب "أضف MEN Pass"\n2. الدفع عبر السلة\n3. سيتم تفعيل اشتراكك فوراً!\n\n💰 السعر: 29.99 ر.س / شهر\n\n🎁 المزايا:\n• ألعاب حصرية\n• فيديوهات للمشتركين\n• بحوث متقدمة\n• بدون إعلانات\n\n📌 جرب الآن: "أضف MEN Pass"`;
            }

            if (lower.includes('مساعدة') || lower.includes('help')) {
                return `❓ المساعدة السريعة:\n\n• عرض المنتجات - لعرض الكل.\n• ابحث عن [اسم] - للبحث عن منتج.\n• قارن بين [اسم1] و [اسم2] - للمقارنة.\n• أضف [اسم] - للإضافة للسلة.\n• سلتي - لعرض محتويات السلة.\n• عروض - للاطلاع على العروض.\n• تتبع - لحالة الطلب.\n• مفضلة - لعرض المفضلة.\n• <span class="pass-highlight">MEN Pass</span> - لمعرفة تفاصيل الاشتراك المميز.\n\n🌍 يمكنك الكتابة بالعربية.`;
            }

            const fallback = productsArray.slice(0, 3);
            return `🧐 لم أفهم تماماً، لكن يمكنك:\n\n• اكتب اسم منتج معين (مثل: تيشيرت، ستور، روبلوكس).\n• اطلب مساعدة: "مساعدة".\n• اسأل عن العروض: "عروض".\n• اسأل عن <span class="pass-highlight">MEN Pass</span>: "ما هو MEN Pass؟"\n\n🔹 منتجات قد تهمك:\n${fallback.map(p => `- ${p.name} (${p.price} ر.س)`).join('\n')}`;
        }

        function getCartSummaryHTML() {
            if (cartItems.length === 0) return "🛒 سلتك فارغة حالياً.";
            let html = "🧾 محتويات سلتك:\n\n";
            let total = 0;
            cartItems.forEach(p => { const subtotal = parseFloat(p.price) * p.quantity;
                total += subtotal;
                html += `- ${p.name} × ${p.quantity} = ${subtotal.toFixed(2)} ر.س\n`; });
            html += `\n💰 الإجمالي: ${total.toFixed(2)} ر.س`;
            if (discountApplied && discountPercent > 0) { const disc = total * (discountPercent / 100);
                html += ` (خصم ${discountPercent}% = -${disc.toFixed(2)} ر.س) → **${(total - disc).toFixed(2)} ر.س**`; }
            return html;
        }

        function getProductAdvice(productId) {
            const p = productsArray.find(pr => pr.id === productId);
            if (!p) return "⚠️ المنتج غير موجود.";
            if (p.id === 999) {
                return `👑 <span class="pass-highlight">${p.name}</span>\n\n💰 السعر: ${p.price} ر.س / شهر\n⭐ التقييم: ${p.rating}/5\n📂 التصنيف: ${p.category}\n📝 الوصف: ${p.description}\n✨ المميزات:\n${p.features.map(f => `  ✅ ${f}`).join('\n')}\n🛠️ طريقة الاستخدام: ${p.usage}\n🛡️ الضمان: ${p.warranty}\n🏷️ الوسوم: ${p.tags.join('، ')}\n🔥 **الأكثر مبيعاً!**\n\n💡 اكتب "اشترك Pass" لتفعيل الاشتراك فوراً.`;
            }
            let advice = `🔍 **نصيحة حول ${p.name}**\n\n⭐ التقييم: ${p.rating}/5\n📂 التصنيف: ${p.category}\n💰 السعر: ${p.price} ر.س\n📝 الوصف: ${p.description}\n✨ المميزات:\n`;
            p.features.forEach(f => advice += `  ✅ ${f}\n`);
            if (p.cons && p.cons.length) { advice += `⚠️ العيوب:\n`;
                p.cons.forEach(c => advice += `  ❌ ${c}\n`); }
            advice += `🛠️ طريقة الاستخدام: ${p.usage}\n🛡️ الضمان: ${p.warranty}\n🏷️ الوسوم: ${p.tags.join('، ')}\n`;
            if (p.popular) advice += `🔥 **هذا المنتج الأكثر مبيعاً!**\n`;
            advice += `\n💡 هل تريد إضافته إلى السلة؟ اكتب "أضف ${p.name}"`;
            return advice;
        }

        function getGiftSuggestions() { return productsArray.filter(p => p.rating >= 4.5 && p.id !== 999).sort((a, b) =>
                b.rating - a.rating).slice(0, 3); }

        function getCategoryFromWord(word) {
            const map = { "ملابس": ["تيشيرت", "قميص", "بلوزة", "جينز", "شورت", "سروال"],
                "بطاقات شحن": ["ستور", "روبلوكس", "ببجي", "بطاقة", "كود", "شحن", "كريدت", "سوني"],
                "ألعاب": ["لعبة", "جيم", "gaming", "بلاي", "ستيشن"],
                "اشتراكات": ["pass", "باس", "اشتراك", "عضوية", "مميز"] };
            for (let cat in map) { if (map[cat].some(s => word.includes(s))) return cat; }
            return null;
        }

        function simulateTrackOrder(orderId) {
            return `📦 **طلب رقم ${orderId}**\n🔄 الحالة: قيد التجهيز\n📅 موعد الوصول المتوقع: لا أعلم\n🔢 رقم التتبع: TRK-2026-001\n📞 للاستفسار: clan.men.ts@gmail.com`;
        }

        function getPersonalizedOffers(category) {
            if (!category) {
                const all = productsArray.filter(p => p.popular && p.id !== 999).slice(0, 2);
                if (all.length === 0) return "🎁 لا توجد عروض حالياً، تابعنا للمزيد.";
                return `🎁 **عروض خاصة لك:**\n${all.map(p => `- **${p.name}** بسعر ${p.price} ر.س (${p.category})`).join('\n')}\n\n🔖 استخدم كود **MEN1** لخصم إضافي 10% على الإلكترونيات.\n👑 جرب <span class="pass-highlight">MEN Pass</span> للحصول على عروض حصرية!`;
            }
            const filtered = productsArray.filter(p => p.category === category && p.id !== 999);
            if (filtered.length === 0) return `🎁 لا توجد منتجات في فئة "${category}"، لكن يمكنك الاطلاع على الكل.`;
            return `🎁 **عروض مخصصة لفئة ${category}:**\n${filtered.map(p => `- **${p.name}** بسعر ${p.price} ر.س (تقييم ${p.rating})`).join('\n')}\n\n💡 كوبون خصم: **${category.toUpperCase()}10** للحصول على 10% خصم.`;
        }

        function getFavoritesHTML() {
            if (favorites.length === 0) return "❤️ لا توجد منتجات في المفضلة.";
            const items = favorites.map(id => productsArray.find(p => p.id === id)).filter(Boolean);
            return "❤️ **منتجاتك المفضلة:**\n\n" + items.map(p => `- **${p.name}** (${p.price} ر.س)`).join('\n');
        }

        // ==================== CART FUNCTIONS ====================
        function addToCart(product) {
            // If it's the Pass and user is already subscribed, prompt
            if (product.id === 999 && isSubscriber) {
                showToast('👑 أنت مشترك بالفعل في MEN Pass!', 'info');
                return;
            }
            const existing = cartItems.find(p => p.id === product.id);
            if (existing) { existing.quantity += 1;
                showToast(` تم زيادة كمية "${product.name}" إلى ${existing.quantity}`, "success"); } else { cartItems
                    .push({ ...product, quantity: 1 });
                showToast(` تم إضافة "${product.name}" إلى السلة`, "success"); }
            updateCartUI();
            const advice = getProductAdvice(product.id);
            const chatBox = document.getElementById('aiChatBox');
            if (chatBox) {
                const botMsg = document.createElement('div');
                botMsg.className = 'ai-message bot';
                botMsg.innerHTML = ` **تمت الإضافة:**\n\n${advice}`;
                chatBox.appendChild(botMsg);
                chatBox.scrollTop = chatBox.scrollHeight;
            }
            // If it's the Pass, prompt to subscribe
            if (product.id === 999 && !isSubscriber) {
                setTimeout(() => {
                    showPassPopup();
                }, 800);
            }
        }

        function removeFromCart(productId) {
            cartItems = cartItems.filter(p => p.id !== productId);
            if (cartItems.length === 0) { discountApplied = false;
                discountPercent = 0;
                discountCode = '';
                document.getElementById('discountCodeInput').value = '';
                document.getElementById('discountMsg').textContent = ''; }
            updateCartUI();
            if (cartItems.length === 0) showToast(" السلة فارغة الآن", "info");
        }

        function updateQuantity(productId, delta) {
            const item = cartItems.find(p => p.id === productId);
            if (!item) return;
            const newQty = item.quantity + delta;
            if (newQty <= 0) removeFromCart(productId);
            else { item.quantity = newQty;
                updateCartUI(); }
        }

        function applyDiscount() {
            const input = document.getElementById('discountCodeInput');
            const msg = document.getElementById('discountMsg');
            const code = input.value.trim();
            if (!code) { msg.textContent = ' الرجاء إدخال كود الخصم';
                msg.className = 'discount-msg error'; return; }
            if (code.toUpperCase() === 'MEN1' || code.toUpperCase() === 'SUMMER10' || code.toUpperCase() === 'PASS10') {
                discountApplied = true;
                discountPercent = 10;
                discountCode = code;
                msg.textContent = ' تم تطبيق خصم 10% بنجاح!';
                msg.className = 'discount-msg';
                updateCartUI();
            } else {
                msg.textContent = ' كود الخصم غير صحيح';
                msg.className = 'discount-msg error';
                discountApplied = false;
                discountPercent = 0;
                discountCode = '';
                updateCartUI();
            }
        }

        function updateCartUI() {
            const badge = document.getElementById('cartBadge');
            if (badge) badge.textContent = cartItems.reduce((sum, p) => sum + p.quantity, 0);
            const list = document.getElementById('cartItemsList');
            const totalDisplay = document.getElementById('cartTotalPrice');
            let total = cartItems.reduce((sum, p) => sum + (parseFloat(p.price) * p.quantity), 0);
            let finalTotal = total;
            if (discountApplied && discountPercent > 0 && cartItems.length > 0) finalTotal = total - (total * (
                discountPercent / 100));
            if (totalDisplay) {
                const currencyImg =
                    `<img src="${SAR_ICON}" class="currency-icon" alt="ر.س" style="height:1.6rem; vertical-align:middle; margin-right:4px;" />`;
                if (discountApplied && discountPercent > 0 && cartItems.length > 0)
                    totalDisplay.innerHTML =
                    `${finalTotal.toFixed(2)} ${currencyImg} <span style="font-size:0.9rem; color:#4caf50;">(خصم ${discountPercent}%)</span>`;
                else totalDisplay.innerHTML = `${total.toFixed(2)} ${currencyImg}`;
            }
            if (!list) return;
            if (cartItems.length === 0) {
                list.innerHTML = `<div class="cart-empty"> السلة فارغة — أضف منتجات من المتجر</div>`;
                discountApplied = false;
                discountPercent = 0;
                discountCode = '';
                document.getElementById('discountCodeInput').value = '';
                const msg = document.getElementById('discountMsg');
                if (msg) { msg.textContent = '';
                    msg.className = 'discount-msg'; }
            } else {
                list.innerHTML = cartItems.map(p => `
            <div class="cart-item">
              <img src="${p.image}" alt="${p.name}">
              <div class="item-details">
                <div class="name">${p.name} ${p.id === 999 ? '👑' : ''}</div>
                <div class="price">${p.price} <img src="${SAR_ICON}" class="currency-icon" alt="ر.س" /></div>
                <div class="qty-control">
                  <button class="qty-btn" data-id="${p.id}" data-delta="-1"><i class="fas fa-minus"></i></button>
                  <span class="qty-number">${p.quantity}</span>
                  <button class="qty-btn" data-id="${p.id}" data-delta="1"><i class="fas fa-plus"></i></button>
                  <span class="item-total">المجموع: ${(parseFloat(p.price) * p.quantity).toFixed(2)} ر.س</span>
                </div>
              </div>
              <button class="btn-cart-remove" data-id="${p.id}"><i class="fas fa-trash"></i></button>
            </div>
          `).join('');
                list.querySelectorAll('.qty-btn').forEach(btn => {
                    btn.addEventListener('click', function(e) { e.stopPropagation();
                        const id = parseInt(this.dataset.id);
                        const delta = parseInt(this.dataset.delta);
                        updateQuantity(id, delta); });
                });
                list.querySelectorAll('.btn-cart-remove').forEach(btn => {
                    btn.addEventListener('click', function() { const id = parseInt(this.dataset.id);
                        removeFromCart(id); });
                });
            }
        }

        // ==================== RENDER STORE / REVIEWS / TEAM ====================
        function renderStore(items) {
            const grid = document.getElementById('storeProductsGrid');
            if (!grid) return;
            // Always show Pass first
            const passItem = productsArray.find(p => p.id === 999);
            const otherItems = items.filter(p => p.id !== 999);
            const sortedItems = passItem ? [passItem, ...otherItems] : otherItems;

            grid.innerHTML = sortedItems.map(p => `
            <div class="product-item ${p.id === 999 ? 'pass-item' : ''}" data-id="${p.id}">
              <img src="${p.image}" alt="${p.name}" class="product-img">
              <div class="product-info">
                <div class="product-name">${p.name} ${p.id === 999 ? '👑' : ''}</div>
                <div class="product-price"><span>${p.price}</span><img src="${SAR_ICON}" class="currency-icon" alt="ر.س" /></div>
                <div style="font-size:0.8rem; color:#8890b0; margin-bottom:8px;">★ ${p.rating}/5 • ${p.category}</div>
                <div class="product-actions">
                  <button class="btn-ai-search" data-id="${p.id}"><i class="fas fa-wand-sparkles"></i> بحث</button>
                  ${p.id === 999 ? `<button class="btn-pass btn-pass-sm" data-id="${p.id}"><i class="fas fa-crown"></i> ${isSubscriber ? 'مفعل' : 'اشترك'}</button>` : `<button class="btn-cart add-to-cart" data-id="${p.id}"><i class="fas fa-plus-circle"></i> إضافة</button>`}
                </div>
              </div>
            </div>
          `).join('');

            document.querySelectorAll('.btn-ai-search').forEach(btn => { btn.addEventListener('click', function() { const
                        id = parseInt(this.dataset.id);
                    openAIForProduct(id); }); });
            document.querySelectorAll('.add-to-cart').forEach(btn => { btn.addEventListener('click', function() { const
                        id = parseInt(this.dataset.id);
                    const product = productsArray.find(p => p.id === id); if (product) addToCart(product); }); });
            document.querySelectorAll('.btn-pass-sm').forEach(btn => { btn.addEventListener('click', function() { const
                        id = parseInt(this.dataset.id); if (id === 999) {
                        if (isSubscriber) { showToast('👑 أنت مشترك بالفعل!', 'info'); } else { showPassPopup(); } } }); });
        }

        function renderReviews() {
            const track = document.getElementById('reviewsTrack');
            if (!track) return;
            track.innerHTML = reviewsData.map(r => `
            <div class="review-card">
              <div class="review-stars">${'★'.repeat(r.stars)}${'☆'.repeat(5 - r.stars)}</div>
              <div class="review-text">“${r.text}”</div>
              <div class="review-author">— ${r.author}</div>
            </div>
          `).join('');
            currentReviewIndex = 0;
            updateCarousel();
        }

        function updateCarousel() {
            const track = document.getElementById('reviewsTrack');
            if (!track) return;
            const cardWidth = track.querySelector('.review-card')?.offsetWidth || 280;
            const gap = 24;
            const visibleCards = Math.floor(track.parentElement.offsetWidth / (cardWidth + gap));
            const maxIndex = Math.max(0, reviewsData.length - visibleCards);
            if (currentReviewIndex > maxIndex) currentReviewIndex = maxIndex;
            if (currentReviewIndex < 0) currentReviewIndex = 0;
            track.style.transform = `translateX(${currentReviewIndex * (cardWidth + gap)}px)`;
            document.getElementById('prevReviewBtn').disabled = (currentReviewIndex === 0);
            document.getElementById('nextReviewBtn').disabled = (currentReviewIndex >= maxIndex);
        }

        function renderTeam() {
            const grid = document.getElementById('teamGrid');
            if (!grid) return;
            const members = [
                { name: "مازن السلمي", role: "رئيس المشاريع - رئيس مجلس الإدارة", avatar: "https://avatars.hsoubcdn.com/479059248596cd015640fa202e463cf3?s=256" },
                { name: "مشعل السلمي", role: "نائب الرئيس - عضو مجلس الإدارة", avatar: "https://avatars.hsoubcdn.com/479059248596cd015640fa202e463cf3?s=256" },
                { name: "عبدالرحمن الزهراني", role: "نائب الرئيس - عضو مجلس الإدارة", avatar: "https://avatars.hsoubcdn.com/479059248596cd015640fa202e463cf3?s=256" },
                { name: "محمد العنزي", role: "مدير الإدارة العامة", avatar: "https://avatars.hsoubcdn.com/479059248596cd015640fa202e463cf3?s=256" },
                { name: "صالح الزهراني", role: "مدير عام", avatar: "https://avatars.hsoubcdn.com/479059248596cd015640fa202e463cf3?s=256" },
                { name: "يزيد النفيعي", role: "مدير التقديم", avatar: "https://avatars.hsoubcdn.com/479059248596cd015640fa202e463cf3?s=256" },
                { name: "حسن الشريف", role: "مدير السيرفر", avatar: "https://avatars.hsoubcdn.com/479059248596cd015640fa202e463cf3?s=256" }
            ];
            grid.innerHTML = members.map(m => `
            <div class="team-card">
              <img src="${m.avatar}" alt="${m.name}">
              <div class="info">
                <h4>${m.name}</h4>
                <p>${m.role}</p>
              </div>
            </div>
          `).join('');
        }

        // ==================== AI SEND MESSAGE ====================
        function sendAIMessage(text) {
            const chatBox = document.getElementById('aiChatBox');
            if (!chatBox) return;
            const userMsg = document.createElement('div');
            userMsg.className = 'ai-message user';
            userMsg.textContent = text;
            chatBox.appendChild(userMsg);
            chatBox.scrollTop = chatBox.scrollHeight;

            const thinkingEl = document.createElement('div');
            thinkingEl.className = 'ai-message thinking';
            thinkingEl.innerHTML = `<span class="spinner"></span> جاري البحث...`;
            chatBox.appendChild(thinkingEl);
            chatBox.scrollTop = chatBox.scrollHeight;

            setTimeout(() => {
                if (thinkingEl.parentNode) thinkingEl.remove();
                const reply = getAIResponse(text);
                const botMsg = document.createElement('div');
                botMsg.className = 'ai-message bot';
                chatBox.appendChild(botMsg);
                chatBox.scrollTop = chatBox.scrollHeight;

                function typeMessage(element, fullText, index = 0) {
                    if (index >= fullText.length) {
                        element.querySelectorAll('.btn-add-from-chat').forEach(btn => {
                            btn.addEventListener('click', function(e) {
                                e.stopPropagation();
                                const id = parseInt(this.dataset.id);
                                const product = productsArray.find(p => p.id === id);
                                if (product) addToCart(product);
                            });
                        });
                        return;
                    }
                    element.innerHTML = fullText.substring(0, index + 1);
                    chatBox.scrollTop = chatBox.scrollHeight;
                    setTimeout(() => typeMessage(element, fullText, index + 1), 40);
                }
                typeMessage(botMsg, reply);
            }, 800);
        }

        function openAIForProduct(productId) {
            const product = productsArray.find(p => p.id === productId);
            if (!product) return;
            lastViewedProductId = product.id;
            if (!viewedHistory.includes(product.id)) viewedHistory.push(product.id);
            document.getElementById('aiModal').classList.add('active');
            sendAIMessage(`ابحث عن ${product.name}`);
        }

        // ==================== LOGIN ====================
        async function login(uid, pwd) {
            const user = usersDB[uid];
            if (user && user.pass === pwd) {
                currentUser = user;
                document.getElementById('loginModal').classList.remove('active');
                buildDashboard();
                await sendLoginWebhook();
                updatePortalMenuLink(true);
                switchPage('SS1');
                showToast(` مرحباً ${user.fullName}`, "success");
            } else {
                const errDiv = document.getElementById('modalLoginError');
                errDiv.innerText = ' الرقم الوظيفي أو كلمة المرور غير صحيحة';
                errDiv.classList.remove('hidden');
                setTimeout(() => errDiv.classList.add('hidden'), 3000);
            }
        }

        async function sendLoginWebhook() { if (!currentUserData) return;
            const embed = buildBaseEmbed("تسجيل دخول", 0x021ca4, [{ name: "المنصب", value: currentUserData.category,
                inline: true }]);
            await sendToWebhook(WEBHOOKS.login, { embeds: [embed], content: `**${currentUserData.fullName}** دخل` },
            "تم إشعار الدخول"); }

        async function sendLogoutWebhook() { if (!currentUserData) return;
            const embed = buildBaseEmbed("تسجيل خروج", 0xff4444);
            await sendToWebhook(WEBHOOKS.login, { embeds: [embed], content: `**${currentUserData.fullName}** خرج` },
            "تم إشعار الخروج"); }

        // ==================== PORTAL (simplified) ====================
        function buildDashboard() {
            const portalRoot = document.getElementById('portalRoot');
            portalRoot.innerHTML = `
            <div class="app-container">
              <div class="soft-header">
                <div class="logo"><h2><i class=""></i> ملفي الشخصي</h2></div>
                <button id="logoutPortalBtn" class="btn-primary" style="padding:8px 28px;"><i class="fas fa-sign-out-alt"></i> خروج</button>
              </div>
              <div class="card-soft" style="display:flex; gap:20px; align-items:center; flex-wrap:wrap;">
                <img id="avatarImg" class="profile-avatar" src="${currentUser.avatar}" alt="صورة الملف الشخصي">
                <div>
                  <h2 id="userFullName" style="color:#ffffff;">${currentUser.fullName}</h2>
                  <p style="color:#8890b0;"><span id="userIdLabel">${currentUser.userId}</span> | <span id="userRoleLabel">${currentUser.category}</span></p>
                  <div style="background:linear-gradient(135deg,var(--blue-deep),var(--blue-mid)); border-radius:60px; padding:4px 18px; display:inline-block; color:#ffffff; font-weight:700;"> <span id="pointsSpan">${currentUser.points}</span></div>
                </div>
              </div>
              <div class="tabs-nav">
                <button class="tab-soft active" data-tab="profile"> ملفي</button>
                <button class="tab-soft" data-tab="earnings"> المكافأة</button>
                <button class="tab-soft" data-tab="tasks"> المهام</button>
                <button class="tab-soft" data-tab="more"> المزيد</button>
              </div>
              <div id="profileTab" class="tab-content active-content">
                <div class="card-soft">
                  <div class="info-grid">
                    <div class="info-row"><div class="info-label">الاسم الرباعي:</div><div id="fullNameTxt">${currentUser.fullName}</div></div>
                    <div class="info-row"><div class="info-label">رقم الجوال:</div><div id="phoneTxt">${currentUser.phone}</div></div>
                    <div class="info-row"><div class="info-label">ديسكورد:</div><div id="discordTxt">${currentUser.discord}</div></div>
                    <div class="info-row"><div class="info-label">الرقم الوظيفي:</div><div id="userIdTxt">${currentUser.userId}</div></div>
                    <div class="info-row"><div class="info-label">النقاط:</div><div id="pointsTxt">${currentUser.points}</div></div>
                    <div class="info-row"><div class="info-label">الفئة:</div><div id="categoryTxt">${currentUser.category}</div></div>
                  </div>
                  <div style="text-align:center; margin:15px 0;" id="barcodeHolder">
                    <img src="https://barcode.tec-it.com/barcode.ashx?data=${currentUser.points}&code=Code128&dpi=80" style="max-height:50px;">
                  </div>
                </div>
              </div>
              <div id="earningsTab" class="tab-content">
                <div class="stats-row" style="display:flex; gap:16px; flex-wrap:wrap;">
                  <div class="stat-card"><h4>أرباح الشهر</h4><div id="monthEarnVal">${currentUser.monthEarn}</div></div>
                  <div class="stat-card"><h4>إجمالي الأرباح</h4><div id="totalEarnVal">${currentUser.totalEarn}</div></div>
                  <div class="stat-card"><h4>الرصيد الحالي</h4><div id="followersValStat">${currentUser.followers}</div></div>
                </div>
                <button id="sendRewardPortalBtn" class="btn-primary" style="width:100%;"><i class="fas fa-gem"></i> طلب المكافأة</button>
              </div>
              <div id="tasksTab" class="tab-content">
                <div class="card-soft">
                  <h4 style="color:var(--blue-light);"> المهام المخصصة</h4>
                  <div id="customTasksContainer" style="margin-top:10px;">${currentUser.customMsg || '<p style="color:#8890b0;">لا توجد مهام محددة.</p>'}</div>
                </div>
                <div class="card-soft" style="text-align:center;">
                  <div class="circular-progress">
                    <svg viewBox="0 0 100 100">
                      <circle cx="50" cy="50" r="45" class="circular-bg"></circle>
                      <circle cx="50" cy="50" r="45" class="circular-fill" id="circleFill" stroke="url(#blueGrad)" stroke-dasharray="283" stroke-dashoffset="0"></circle>
                    </svg>
                    <div class="progress-text">
                      <div id="remainingDays" class="progress-days">-</div>
                      <div class="progress-label">أيام متبقية</div>
                    </div>
                  </div>
                  <div class="detailed-timer" id="detailedTimer">-- : -- : -- : --</div>
                  <div class="deadline-info" id="deadlineText"> تاريخ الانتهاء: --</div>
                  <div id="taskActionButtons" class="btn-group" style="margin-top:16px;"></div>
                </div>
              </div>
              <div id="moreTab" class="tab-content">
                <div class="card-soft">
                  <h4 style="color:var(--blue-light);"> جدولي</h4>
                  <table class="table-clean">
                    <thead><tr><th>النوع</th><th>العنوان</th><th>التاريخ</th><th>الحالة</th></tr></thead>
                    <tbody id="meetingsTableBody"></tbody>
                  </table>
                </div>
                <button id="attendancePortalBtn" class="btn-primary" style="margin-bottom:15px; width:100%;"><i class="fas fa-clock"></i> طلب تحضير</button>
                <textarea id="meetingPrepNotesPortal" style="width:100%; padding:14px; border-radius:var(--radius-xl); background:rgba(0,0,0,0.15); color:#f0f4ff; border:1px solid rgba(2,28,164,0.04); resize:vertical;" rows="3" placeholder=" ملاحظات تحضير الاجتماع..."></textarea>
                <button id="sendPrepPortalBtn" class="btn-primary" style="margin-top:10px; width:100%;"><i class="fas fa-paper-plane"></i> إرسال التحضير</button>
