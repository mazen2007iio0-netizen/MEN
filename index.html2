            // Re-bind portal events
            document.getElementById('logoutPortalBtn')?.addEventListener('click', async () => {
                await sendLogoutWebhook();
                currentUser = null;
                currentUserData = null;
                document.getElementById('portalRoot').innerHTML =
                    `<div class="card-soft" style="text-align:center; padding:40px;"><p style="color:#8890b0;"> تم تسجيل الخروج</p></div>`;
                updatePortalMenuLink(false);
                showToast(" تم الخروج", "info");
                switchPage('home');
            });
            document.getElementById('sendRewardPortalBtn')?.addEventListener('click', () => {
                showToast(' تم طلب المكافأة', 'success');
            });
            document.getElementById('attendancePortalBtn')?.addEventListener('click', () => {
                showToast(' تم تسجيل الدوام', 'success');
            });
            document.getElementById('sendPrepPortalBtn')?.addEventListener('click', () => {
                const notes = document.getElementById('meetingPrepNotesPortal').value;
                if (notes.trim()) showToast(' تم إرسال التحضير', 'success');
                else showToast(' أدخل ملاحظات', 'error');
            });

            const tabs = document.querySelectorAll('.tab-soft');
            const contents = {
                profile: document.getElementById('profileTab'),
                earnings: document.getElementById('earningsTab'),
                tasks: document.getElementById('tasksTab'),
                more: document.getElementById('moreTab')
            };
            tabs.forEach(btn => {
                btn.addEventListener('click', () => {
                    const tab = btn.getAttribute('data-tab');
                    Object.values(contents).forEach(c => c?.classList.remove('active-content'));
                    if (contents[tab]) contents[tab].classList.add('active-content');
                    tabs.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                });
            });

            // Render meetings
            const tbody = document.getElementById('meetingsTableBody');
            if (tbody && currentUser.meetings) {
                tbody.innerHTML = currentUser.meetings.map(m =>
                    `<tr><td>${m.type}</td><td>${m.title}</td><td>${m.date}</td><td><span style="background:${m.status === 'حضر' ? '#4caf5020' : m.status === 'قادم' ? '#f5b34220' : '#ff6b6b20'}; color:${m.status === 'حضر' ? '#4caf50' : m.status === 'قادم' ? '#f5b342' : '#ff6b6b'}; padding:2px 12px; border-radius:30px; font-size:0.8rem;">${m.status}</span></td></tr>`
                ).join('');
            }
        }

        function updatePortalMenuLink(isLoggedIn) {
            const dropdown = document.getElementById('dropdownMenu');
            let portalLink = dropdown.querySelector('a[data-page="SS1"]');
            if (isLoggedIn && !portalLink) {
                const newLink = document.createElement('a');
                newLink.setAttribute('data-page', 'SS1');
                newLink.innerHTML = '<i class="fas fa-id-card"></i> بوابتي';
                newLink.style.cursor = 'pointer';
                newLink.addEventListener('click', (e) => { e.preventDefault();
                    switchPage('SS1');
                    closeDropdown(); });
                const newsLink = dropdown.querySelector('a[data-page="news"]');
                newsLink.insertAdjacentElement('afterend', newLink);
            } else if (!isLoggedIn && portalLink) portalLink.remove();
        }

        // ==================== INIT AI ASSISTANT ====================
        function initAIAssistant() {
            const modal = document.getElementById('aiModal');
            const openBtn = document.getElementById('aiAssistantBtn');
            const closeBtn = document.getElementById('aiModalClose');
            const sendBtn = document.getElementById('aiSendBtn');
            const input = document.getElementById('aiUserInput');
            openBtn.addEventListener('click', () => { modal.classList.add('active');
                setTimeout(() => input.focus(), 200); });
            closeBtn.addEventListener('click', () => modal.classList.remove('active'));
            modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('active'); });
            sendBtn.addEventListener('click', () => { const text = input.value.trim(); if (text) { sendAIMessage(
                        text);
                    input.value = ''; } });
            input.addEventListener('keydown', (e) => { if (e.key === 'Enter') { const text = input.value.trim(); if (
                        text) { sendAIMessage(text);
                        input.value = ''; } } });
            document.querySelectorAll('.ai-quick-btns .qbtn').forEach(btn => {
                btn.addEventListener('click', function() { const query = this.dataset.query; if (query)
                        sendAIMessage(query); });
            });
        }

        // ==================== CART MODAL ====================
        function initCartModal() {
            document.getElementById('cartModalClose').addEventListener('click', () => document.getElementById(
                'cartModal').classList.remove('active'));
            document.getElementById('cartModal').addEventListener('click', (e) => { if (e.target === document
                    .getElementById('cartModal')) document.getElementById('cartModal').classList.remove(
                'active'); });
            document.getElementById('cartSubmitBtn').addEventListener('click', () => {
                const name = document.getElementById('cartUserName').value.trim();
                const phone = document.getElementById('cartUserPhone').value.trim();
                // Check if Pass is in cart and not subscribed
                const hasPass = cartItems.some(p => p.id === 999);
                if (hasPass && !isSubscriber) {
                    // Auto-subscribe when purchasing Pass
                    const passItem = cartItems.find(p => p.id === 999);
                    if (passItem) {
                        // Remove the pass from cart since we're subscribing
                        removeFromCart(999);
                        subscribeToPass();
                        showToast('👑 تم تفعيل اشتراك MEN Pass!', 'success');
                        return;
                    }
                }
                sendCartRequest(name, phone);
            });
            document.getElementById('cartToggleBtn').addEventListener('click', () => { updateCartUI();
                document.getElementById('cartModal').classList.add('active'); });
            document.getElementById('applyDiscountBtn').addEventListener('click', applyDiscount);
            document.getElementById('discountCodeInput').addEventListener('keydown', (e) => { if (e.key ===
                    'Enter') applyDiscount(); });
            updateCartUI();
        }

        async function sendCartRequest(userName, userPhone) {
            if (cartItems.length === 0) { showToast(" السلة فارغة، أضف منتجات أولاً", "error"); return; }
            if (!userName || !userPhone) { showToast(" يرجى إدخال الاسم ورقم الجوال", "error"); return; }
            let productList = cartItems.map((p, i) =>
                `${i+1}. ${p.name} (الكمية: ${p.quantity}) - ${(parseFloat(p.price) * p.quantity).toFixed(2)} ر.س`
                ).join('\n');
            let total = cartItems.reduce((sum, p) => sum + (parseFloat(p.price) * p.quantity), 0);
            let finalTotal = total;
            if (discountApplied && discountPercent > 0) finalTotal = total - (total * (discountPercent / 100));
            const embed = {
                title: " طلب جديد من المتجر",
                color: 0x021ca4,
                fields: [
                    { name: "العميل", value: userName, inline: true },
                    { name: "رقم الجوال", value: userPhone, inline: true },
                    { name: "إجمالي القطع", value: cartItems.reduce((sum, p) => sum + p.quantity, 0).toString(),
                        inline: true },
                    { name: "الإجمالي قبل الخصم", value: `${total.toFixed(2)} ر.س`, inline: true },
                    ...(discountApplied && discountPercent > 0 ? [{ name: "الخصم",
                        value: `-${(total * (discountPercent / 100)).toFixed(2)} ر.س (${discountPercent}%)`,
                        inline: true }] : []),
                    { name: "الإجمالي النهائي", value: `${finalTotal.toFixed(2)} ر.س`, inline: true },
                    { name: "المنتجات", value: productList.substring(0, 1000), inline: false },
                    { name: "الوقت", value: new Date().toLocaleString('ar-SA'), inline: true }
                ],
                thumbnail: { url: cartItems[0]?.image || '' },
                timestamp: new Date().toISOString()
            };
            try {
                await fetch(WEBHOOKS.cart, { method: "POST", headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ embeds: [embed], content: ` طلب جديد من ${userName}` }) });
                showToast(" تم إرسال طلبك بنجاح!", "success");
                cartItems = [];
                discountApplied = false;
                discountPercent = 0;
                discountCode = '';
                document.getElementById('discountCodeInput').value = '';
                document.getElementById('discountMsg').textContent = '';
                updateCartUI();
                document.getElementById('cartModal').classList.remove('active');
            } catch (e) { showToast(" فشل في الإرسال، حاول مرة أخرى", "error"); }
        }

        // ==================== PAGE NAVIGATION ====================
        function switchPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId)?.classList.add('active');
            document.querySelectorAll('.dropdown-menu a').forEach(a => a.classList.remove('active-drop'));
            const activeLink = document.querySelector(`.dropdown-menu a[data-page="${pageId}"]`);
            if (activeLink) activeLink.classList.add('active-drop');
            window.scrollTo({ top: 0, behavior: 'smooth' });
            closeDropdown();
            if (pageId === 'store') setTimeout(updateCarousel, 120);
            // If switching to store, render products
            if (pageId === 'store') renderStore(productsArray);
            // If home, update UI
            if (pageId === 'home') updateUIForSubscription();
        }

        function closeDropdown() { document.getElementById('dropdownMenu').classList.remove('show'); }

        function toggleDropdown(e) { e.stopPropagation();
            document.getElementById('dropdownMenu').classList.toggle('show'); }

        // ==================== INIT ====================
        function initStats() {
            document.querySelectorAll('#about .number, #home .stats-showcase .number').forEach(stat => {
                const target = +stat.getAttribute('data-target');
                let cur = 0;
                const inc = target / 50;
                const upd = () => { cur += inc; if (cur < target) { stat.innerText = Math.ceil(cur);
                        requestAnimationFrame(upd); } else stat.innerText = target; };
                upd();
            });
        }

        function initStore() {
            renderStore(productsArray);
            renderReviews();
            renderTeam();
            initCartModal();
            initAIAssistant();

            // Check subscription status
            checkSubscription();
            updateUIForSubscription();

            document.getElementById('storeSearchInput')?.addEventListener('input', (e) => {
                const term = e.target.value.toLowerCase().trim();
                if (term === '') renderStore(productsArray);
                else { const filtered = productsArray.filter(p => p.name.toLowerCase().includes(term) || p
                        .tags.some(t => t.includes(term)));
                    renderStore(filtered); }
            });

            document.getElementById('prevReviewBtn')?.addEventListener('click', () => { if (currentReviewIndex >
                    0) { currentReviewIndex--;
                        updateCarousel(); } });
            document.getElementById('nextReviewBtn')?.addEventListener('click', () => {
                const track = document.getElementById('reviewsTrack');
                if (!track) return;
                const cardWidth = track.querySelector('.review-card')?.offsetWidth || 280;
                const gap = 24;
                const visibleCards = Math.floor(track.parentElement.offsetWidth / (cardWidth + gap));
                const maxIndex = Math.max(0, reviewsData.length - visibleCards);
                if (currentReviewIndex < maxIndex) { currentReviewIndex++;
                    updateCarousel(); }
            });
            window.addEventListener('resize', updateCarousel);
            document.getElementById('headerLoginBtn2')?.addEventListener('click', () => document.getElementById(
                'loginModal').classList.add('active'));

            // FAQ toggle
            document.querySelectorAll('.faq-item').forEach(item => {
                item.addEventListener('click', function() {
                    this.classList.toggle('active');
                });
            });

            // Show more games buttons
            document.getElementById('showMoreGamesBtn')?.addEventListener('click', function() {
                if (isSubscriber) {
                    document.querySelectorAll('#gamesGrid .premium-game').forEach(el => el.style.display = 'block');
                    this.textContent = '✅ جميع الألعاب معروضة';
                    this.disabled = true;
                } else {
                    showToast('👑 هذه الألعاب حصرية لمشتركي MEN Pass. اشترك الآن!', 'info');
                    showPassPopup();
                }
            });

            document.getElementById('showMoreGamesBtn2')?.addEventListener('click', function() {
                if (isSubscriber) {
                    document.querySelectorAll('#newsGamesGrid .premium-game').forEach(el => el.style.display =
                    'block');
                    this.textContent = '✅ جميع الألعاب معروضة';
                    this.disabled = true;
                } else {
                    showToast('👑 هذه الألعاب حصرية لمشتركي MEN Pass. اشترك الآن!', 'info');
                    showPassPopup();
                }
            });

            // Pass buttons
            document.getElementById('passBannerBtn')?.addEventListener('click', showPassPopup);
            document.getElementById('heroPassBtn')?.addEventListener('click', showPassPopup);
            document.getElementById('storePassBtn')?.addEventListener('click', showPassPopup);

            // Pass popup
            document.getElementById('passPopupClose')?.addEventListener('click', () => document.getElementById(
                'passPopup').classList.remove('active'));
            document.getElementById('passPopupCloseBtn')?.addEventListener('click', () => document.getElementById(
                'passPopup').classList.remove('active'));
            document.getElementById('passPopup')?.addEventListener('click', (e) => {
                if (e.target === document.getElementById('passPopup')) document.getElementById('passPopup')
                    .classList.remove('active');
            });
            document.getElementById('passPopupSubscribe')?.addEventListener('click', subscribeToPass);
        }

        // ==================== EVENT LISTENERS ====================
        document.getElementById('menuToggleBtn').addEventListener('click', toggleDropdown);
        document.addEventListener('click', function(e) {
            const menu = document.getElementById('dropdownMenu');
            if (!menu.contains(e.target) && e.target !== document.getElementById('menuToggleBtn')) closeDropdown();
        });
        document.querySelectorAll('.dropdown-menu a[data-page]').forEach(link => {
            link.addEventListener('click', (e) => { e.preventDefault();
                const page = link.getAttribute('data-page'); if (page) switchPage(page); });
        });
        document.getElementById('headerLoginBtn').addEventListener('click', () => document.getElementById('loginModal')
            .classList.add('active'));
        document.querySelector('.modal-close').addEventListener('click', () => document.getElementById('loginModal')
            .classList.remove('active'));
        document.getElementById('modalLoginBtn').addEventListener('click', () => {
            const uid = document.getElementById('modalEmpId').value.trim().toUpperCase();
            const pwd = document.getElementById('modalEmpPass').value.trim();
            login(uid, pwd);
        });
        document.getElementById('loginModal').addEventListener('click', (e) => {
            if (e.target === document.getElementById('loginModal')) document.getElementById('loginModal').classList
                .remove('active');
        });

        // ===== HEADER SCROLL =====
        window.addEventListener('scroll', () => {
            const header = document.getElementById('mainHeader');
            if (window.scrollY > 30) header.classList.add('scrolled');
            else header.classList.remove('scrolled');
        });

        // ===== إخفاء الإعلان الثابت =====
        document.getElementById('closeAdBtn')?.addEventListener('click', function() {
            const ad = document.getElementById('fixedAd');
            ad.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
            ad.style.opacity = '0';
            ad.style.transform = 'scale(0.8)';
            setTimeout(() => {
                ad.style.display = 'none';
            }, 400);
        });

        // ==================== START ====================
        initStore();
        initStats();

        // Show a welcome toast about MEN Pass
        setTimeout(() => {
            if (!isSubscriber) {
                showToast('👑 اكتشف MEN Pass — ألعاب حصرية، فيديوهات، بحوث وبدون إعلانات!', 'info');
            } else {
                showToast('👑 مرحباً بك في MEN Pass! استمتع بكل المزايا الحصرية.', 'success');
            }
        }, 1500);

        console.log('🚀 MEN website loaded with MEN Pass subscription system!');
        console.log('📊 Subscriber status:', isSubscriber ? 'ACTIVE' : 'INACTIVE');
    </script>
</body>
</html>
